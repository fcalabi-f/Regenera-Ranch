{
  "name": "regenera-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo de Regenera Ranch: mobile (Expo), web (Next.js) y shared (tipos + lógica pura).",
  "workspaces": [
    "shared",
    "regenera-ranch",
    "regenera-ranch-web"
  ],
  "scripts": {
    "mobile": "npm --workspace regenera-ranch run start",
    "web": "npm --workspace regenera-ranch-web run dev",
    "shared:build": "npm --workspace @regenera/shared run build",
    "typecheck": "npm --workspaces --if-present run typecheck"
  }
}
